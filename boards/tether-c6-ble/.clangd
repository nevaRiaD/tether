# clangd configuration for this ESP-IDF project (ESP32-C6 / RISC-V).
#
# clangd reads the compiler invocations from build/compile_commands.json, which
# is generated by the GCC-based riscv32-esp-elf toolchain. A few of those flags
# are GCC-only and make clang error out, so strip them here.
#
# Requires (set in .vscode/settings.json, since .vscode/ is gitignored):
#   clangd.path           -> the Espressif clangd build (esp-clang)
#   --query-driver=**     -> lets clangd query riscv32-esp-elf-gcc for the
#                            toolchain's system include paths
#   --compile-commands-dir=<project>/build
CompileFlags:
  Remove:
    - -f*   # e.g. -fno-tree-switch-conversion, -fstrict-volatile-bitfields
    - -m*   # e.g. -march=rv32imac_zicsr_zifencei, -mabi=ilp32
  Add:
    - -Wno-unknown-warning-option

Diagnostics:
  # ESP-IDF uses GCC-specific warning flags and attributes clang doesn't know.
  Suppress:
    - unknown-warning-option
